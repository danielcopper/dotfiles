#!/bin/bash
# Moonlight mit Monitor-Auswahl

# Monitore aus Hyprland holen
monitors=$(hyprctl monitors -j | jq -r '.[] | "\(.name) (\(.width)x\(.height))"')

# Monitor per Walker auswählen
selected=$(echo "$monitors" | walker -d -p "Monitor für Moonlight")

# Abbruch wenn nichts gewählt
[[ -z "$selected" ]] && exit 0

# Monitor-Name extrahieren (z.B. "DP-2" aus "DP-2 (2560x1440)")
monitor=$(echo "$selected" | cut -d' ' -f1)

# Temporäre Rule setzen
hyprctl keyword windowrule "monitor $monitor,class:^(com.moonlight_stream.Moonlight)$"
hyprctl keyword windowrule "fullscreen,class:^(com.moonlight_stream.Moonlight)$"

# Moonlight starten
moonlight

# Rules nach Beenden entfernen (optional)
hyprctl keyword windowrule "unset,class:^(com.moonlight_stream.Moonlight)$"
