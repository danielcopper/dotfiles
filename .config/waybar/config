{
  "layer": "top",
  "position": "top",
  "height": 39,
  "spacing": 4,
  "margin-top": 0,
  "margin-left": 6,
  "margin-right": 6,

  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],

  "modules-center": [
    "custom/weather",
    "clock"
  ],

  "modules-right": [
    "tray",
    "group/audio",
    "group/connectivity",
    "group/stats",
    "group/power-menu"
  ],

  "hyprland/workspaces": {
    "format": "{name}: {icon}",
    "format-icons": {
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    },
    "persistent-workspaces": {
      "DP-1": [1, 4, 7],
      "DP-2": [2, 5, 8],
      "DP-3": [3, 6, 9]
    },
    "on-click": "activate",
    "sort-by-number": true
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 40,
    "separate-outputs": true
  },

  "custom/weather": {
    "format": "{}",
    "tooltip": true,
    "interval": 1800,
    "exec": "wttrbar --custom-indicator '{ICON} {temp_C}┬░' --lang de",
    "return-type": "json"
  },

  "clock": {
    "format": "┬╖ {:%d ┬╖ %H:%M}",
    "format-alt": "{:%H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "right",
      "format": {
        "months": "<span color='#cebdfe'><b>{}</b></span>",
        "days": "<span color='#e6e1e9'><b>{}</b></span>",
        "weeks": "<span color='#938f99'><b>W{}</b></span>",
        "weekdays": "<span color='#efb8c9'><b>{}</b></span>",
        "today": "<span color='#cebdfe'><b><u>{}</u></b></span>"
      }
    }
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  },

  "group/audio": {
    "orientation": "horizontal",
    "modules": ["pulseaudio"]
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "{icon} {volume}%",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"],
      "muted": "Ό╗ρ"
    },
    "on-click": "pavucontrol",
    "on-scroll-up": "swayosd-client --output-volume raise",
    "on-scroll-down": "swayosd-client --output-volume lower"
  },

  "group/connectivity": {
    "orientation": "horizontal",
    "modules": ["bluetooth", "network"]
  },

  "bluetooth": {
    "format": "≤░Γψ",
    "format-disabled": "≤░Γ▓",
    "format-connected": "≤░Γ▒ {num_connections}",
    "tooltip-format": "{controller_alias}\n{status}",
    "tooltip-format-connected": "{controller_alias}\n{num_connections} verbunden\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "≤░Γ▒ {device_alias}",
    "on-click": "bzmenu -l walker"
  },

  "network": {
    "interval": 2,
    "format-wifi": "≤░Ψσ {signalStrength}% έΗΥ{bandwidthDownBytes} έΗΣ{bandwidthUpBytes}",
    "format-ethernet": "≤░ΙΑ έΗΥ{bandwidthDownBytes} έΗΣ{bandwidthUpBytes}",
    "format-disconnected": "≤░Ψς",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "networkmanager_dmenu"
  },

  "group/stats": {
    "orientation": "horizontal",
    "modules": ["custom/cpu", "temperature", "memory", "custom/gpu", "battery"]
  },

  "custom/cpu": {
    "exec": "~/.config/waybar/scripts/cpu-sparkline.sh",
    "interval": 2,
    "tooltip": false,
    "format": "{}"
  },

  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "format": "≤░ΦΠ {temperatureC}┬░C",
    "critical-threshold": 80,
    "tooltip": true
  },

  "memory": {
    "format": " {used:0.1f}G/{total:0.1f}G",
    "interval": 2,
    "tooltip-format": "{percentage}% used"
  },

  "custom/gpu": {
    "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null || echo 'N/A'",
    "format": "<span font_size='14pt'>≤░λχ</span> {}%",
    "interval": 2,
    "tooltip": true
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "≤░ΓΕ {capacity}%",
    "format-plugged": "≤░γξ {capacity}%",
    "format-icons": ["≤░ΓΟ", "≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"],
    "tooltip-format": "{timeTo}"
  },

  "group/power-menu": {
    "orientation": "horizontal",
    "modules": ["custom/power"]
  },

  "custom/power": {
    "format": "ΎΑΣ",
    "tooltip": false,
    "on-click": "wlogout -l ~/.config/wlogout/layout -C ~/.config/wlogout/style.css -b 5 -L 600 -R 600 -T 450 -B 450"
  }
}
