{
  "layer": "top",
  "position": "top",
  "height": 39,
  "spacing": 4,
  "margin-top": 0,
  "margin-left": 6,
  "margin-right": 6,

  "modules-left": [
    "hyprland/workspaces",
    "hyprland/window"
  ],

  "modules-center": [
    "custom/weather",
    "clock"
  ],

  "modules-right": [
    "group/systray",
    "group/audio",
    "group/connectivity",
    "group/stats",
    "group/power-menu"
  ],

  "hyprland/workspaces": {
    "format": "{name}: {icon}",
    "format-icons": {
      "active": "",
      "default": ""
    },
    "persistent-workspaces": {
      "DP-1": [1, 4, 7],
      "DP-2": [2, 5, 8],
      "DP-3": [3, 6, 9]
    },
    "on-click": "activate",
    "sort-by-number": true
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 40,
    "separate-outputs": true
  },

  "custom/weather": {
    "format": "{}",
    "tooltip": true,
    "interval": 1800,
    "exec": "wttrbar --custom-indicator '{ICON} {temp_C}°' --lang de",
    "return-type": "json"
  },

  "clock": {
    "format": "· {:%d · %H:%M}",
    "format-alt": "{:%H:%M}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "weeks-pos": "right",
      "format": {
        "months": "<span color='#cebdfe'><b>{}</b></span>",
        "days": "<span color='#e6e1e9'><b>{}</b></span>",
        "weeks": "<span color='#938f99'><b>W{}</b></span>",
        "weekdays": "<span color='#efb8c9'><b>{}</b></span>",
        "today": "<span color='#cebdfe'><b><u>{}</u></b></span>"
      }
    }
  },

  "group/systray": {
    "orientation": "horizontal",
    "modules": ["tray"]
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  },

  "group/audio": {
    "orientation": "horizontal",
    "modules": ["pulseaudio"]
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "{icon} {volume}%",
    "format-icons": {
      "default": ["", "", ""],
      "muted": ""
    },
    "on-click": "pavucontrol",
    "on-scroll-up": "swayosd-client --output-volume raise",
    "on-scroll-down": "swayosd-client --output-volume lower"
  },

  "group/connectivity": {
    "orientation": "horizontal",
    "modules": ["bluetooth", "network"]
  },

  "bluetooth": {
    "format": "󰂯",
    "format-disabled": "󰂲",
    "format-connected": "󰂱 {num_connections}",
    "tooltip-format": "{controller_alias}\n{status}",
    "tooltip-format-connected": "{controller_alias}\n{num_connections} verbunden\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "󰂱 {device_alias}",
    "on-click": "bzmenu -l walker"
  },

  "network": {
    "interval": 2,
    "format-wifi": "󰖩 {signalStrength}% ↓{bandwidthDownBytes} ↑{bandwidthUpBytes}",
    "format-ethernet": "󰈀 ↓{bandwidthDownBytes} ↑{bandwidthUpBytes}",
    "format-disconnected": "󰖪",
    "tooltip-format-wifi": "{essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "networkmanager_dmenu"
  },

  "group/stats": {
    "orientation": "horizontal",
    "modules": ["custom/cpu", "temperature", "memory", "custom/gpu", "battery"]
  },

  "custom/cpu": {
    "exec": "~/.config/waybar/scripts/cpu-sparkline.sh",
    "interval": 2,
    "tooltip": false,
    "format": "{}"
  },

  "temperature": {
    "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
    "format": "󰔏 {temperatureC}°C",
    "critical-threshold": 80,
    "tooltip": true
  },

  "memory": {
    "format": " {used:0.1f}G/{total:0.1f}G",
    "interval": 2,
    "tooltip-format": "{percentage}% used"
  },

  "custom/gpu": {
    "exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null || echo 'N/A'",
    "format": "<span font_size='14pt'>󰢮</span> {}%",
    "interval": 2,
    "tooltip": true
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": "󰚥 {capacity}%",
    "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "tooltip-format": "{timeTo}"
  },

  "group/power-menu": {
    "orientation": "horizontal",
    "modules": ["custom/power"]
  },

  "custom/power": {
    "format": "",
    "tooltip": false,
    "on-click": "~/.config/hypr/scripts/wlogout-wrapper.sh"
  }
}
