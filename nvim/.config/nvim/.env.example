# Copy to .env and fill in your tokens. The .env file is gitignored.
# Loaded at startup by init.lua and exported into vim.env (visible to subprocesses).

# Claude Code integration (lua/plugins/claudecode.lua)
ANTHROPIC_API_KEY=

# Azure DevOps PR client (lua/plugins/adopure.lua)
AZURE_DEVOPS_EXT_PAT=

# SonarQube / SonarCloud (lua/plugins/sonarlint.lua)
# Set SONARQUBE_URL for a self-hosted SonarQube server, or SONARCLOUD_ORG for
# SonarQube Cloud. Leave both blank to run sonarlint in standalone mode.
SONARQUBE_URL=
SONARCLOUD_ORG=

# Token for either SonarQube Server or SonarQube Cloud (SONAR_TOKEN also accepted)
SONARQUBE_TOKEN=
