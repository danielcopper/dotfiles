# Pull distro-wide defaults first so a personal ~/.inputrc only overrides
# (and doesn't accidentally drop) keybindings the system ships with.
$include /etc/inputrc

#############################
#       Editing mode        #
#############################
# vi-mode is intentionally Bash-only — affects every readline consumer
# otherwise (Python REPL, psql, sqlcmd, sqlite3 etc.) and the modal
# behaviour is jarring there. Drop the $if Bash wrapper if you actually
# want it everywhere.
$if Bash
        set editing-mode vi
        # Show current mode in prompt
        set show-mode-in-prompt on
        # Set cursor style depending on mode
        $if term=linux
                set vi-ins-mode-string \1\e[?0c\2
                set vi-cmd-mode-string \1\e[?8c\2
        $else
                set vi-ins-mode-string \1\e[6 q\2
                set vi-cmd-mode-string \1\e[2 q\2
        $endif
$endif

############################
#       Completion         #
############################
# Single Tab partially completes or shows all possible completions
set show-all-if-ambiguous on
# Enable case INsensitive cd completion
set completion-ignore-case on

############################
#         Color            #
############################
# Color files by type
set colored-stats on
# Append char to indicate type
set visible-stats on
# Mark symlinked directories
set mark-symlinked-directories on
# Color the common prefix
set colored-completion-prefix on

#############################
#        Other Stuff        #
#############################
# Don't show ^C after pressing Ctrl+C
set echo-control-characters off
# Ensure pasting inserts the clipboard as a single string instead of
# inserting characters as if they were entered from the keyboard.
# Safety measure: prevents Readline from auto-modifying / running pasted
# commands.
set enable-bracketed-paste on
