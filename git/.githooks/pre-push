#!/usr/bin/env bash
# Pre-push hook: scan all commits being pushed for secrets via gitleaks.
# Runs globally because git/.gitconfig sets core.hooksPath = ~/.githooks.
# Bypass on a single push with `git push --no-verify`.

set -euo pipefail

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "pre-push: gitleaks is not installed but required by this hook." >&2
  echo "          install via: sudo pacman -S gitleaks" >&2
  echo "          bypass with: git push --no-verify" >&2
  exit 1
fi

zero='0000000000000000000000000000000000000000'
exit_status=0

while read -r local_ref local_sha remote_ref remote_sha; do
  # Branch deletion — nothing to scan.
  if [ "$local_sha" = "$zero" ]; then
    continue
  fi

  if [ "$remote_sha" = "$zero" ]; then
    # New branch on the remote — scan everything reachable from local_sha
    # that isn't already on another branch or remote-tracking ref.
    range="$local_sha --not --branches --remotes"
  else
    # Updating an existing branch — scan the new commits only.
    range="${remote_sha}..${local_sha}"
  fi

  if ! gitleaks detect --redact --no-banner --log-opts="$range"; then
    echo "pre-push: gitleaks found secrets in commits being pushed to $remote_ref" >&2
    echo "          push aborted. fix the commits or rewrite history first." >&2
    exit_status=1
  fi
done

exit $exit_status
