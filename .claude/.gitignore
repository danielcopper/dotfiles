# Claude Code - Sensitive and temporary files
# Include this in your dotfiles to avoid committing sensitive data

# Credentials and API keys
.credentials.json
*.key
*.pem

# Session data
history.jsonl
session-env/
projects/

# Temporary files
debug/
shell-snapshots/
file-history/
todos/

# Stats and analytics
statsig/
stats-cache.json

# Hook logs (these contain session data)
hooks/logs/

# Local/sensitive settings
settings.local.json
settings-for-api-key.json

# Runtime state
feature-progress/
plans/
cache/
downloads/
ide/
paste-cache/
plugins/
shared/
tasks/
telemetry/

# Keep these (configuration and custom code)
# settings.json
# README.md
# hooks/*.py (but not logs/)
# skills/
# agents/
# commands/
