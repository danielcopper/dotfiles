# Brew packages installed on steamdeck hosts.
# Used instead of common.pkglist/steamdeck.pkglist because SteamOS root is
# read-only and pacman installs don't survive system updates.
# One name per line. Blank lines and lines starting with `#` are ignored.

bash-completion@2
fastfetch
fd
fzf
git
gitleaks
jq
lazygit
lsd
mise
neovim
ripgrep
starship
stow
tmux
tree-sitter
zoxide
