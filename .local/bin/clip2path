#!/usr/bin/env bash
set -euo pipefail

# Detect flatpak and use flatpak-spawn to run commands on the host
if [ -f "/.flatpak-info" ]; then
    SETUP='export PATH="/home/linuxbrew/.linuxbrew/bin:/home/deck/.nix-profile/bin:$PATH"; export DISPLAY="${DISPLAY:-:0}"; export XAUTHORITY=$(ls /run/user/1000/xauth_* 2>/dev/null | head -1);'

    types=$(flatpak-spawn --host bash -c "${SETUP} xclip -selection clipboard -t TARGETS -o 2>/dev/null" || true)

    if echo "$types" | grep -q '^image/'; then
        ext=$(echo "$types" | grep -m1 '^image/' | cut -d/ -f2 | cut -d';' -f1)
        file="/tmp/clip_$(date +%s).${ext}"
        # Write image on the host /tmp so it's visible outside flatpak
        flatpak-spawn --host bash -c "${SETUP} xclip -selection clipboard -t \"image/${ext}\" -o > ${file}"
        echo -n "$file"
    else
        flatpak-spawn --host bash -c "${SETUP} xclip -selection clipboard -o"
    fi
else
    # Running natively (not in flatpak)
    export PATH="/home/linuxbrew/.linuxbrew/bin:/home/deck/.nix-profile/bin:$PATH"
    export DISPLAY="${DISPLAY:-:0}"
    for f in /run/user/$(id -u)/xauth_*; do
        [ -f "$f" ] && export XAUTHORITY="$f" && break
    done

    if [ -n "${WAYLAND_DISPLAY:-}" ]; then
        types=$(wl-paste --list-types 2>/dev/null || true)
        if grep -q '^image/' <<<"$types"; then
            ext=$(grep -m1 '^image/' <<<"$types" | cut -d/ -f2 | cut -d';' -f1)
            file="/tmp/clip_$(date +%s).${ext}"
            wl-paste > "$file"
            echo -n "$file"
        else
            wl-paste --no-newline
        fi
    elif [ -n "${DISPLAY:-}" ]; then
        types=$(xclip -selection clipboard -t TARGETS -o 2>/dev/null || true)
        if grep -q '^image/' <<<"$types"; then
            ext=$(grep -m1 '^image/' <<<"$types" | cut -d/ -f2 | cut -d';' -f1)
            file="/tmp/clip_$(date +%s).${ext}"
            xclip -selection clipboard -t "image/${ext}" -o > "$file"
            echo -n "$file"
        else
            xclip -selection clipboard -o
        fi
    else
        echo "No display found" >&2
        exit 1
    fi
fi
